# Copy this file to .env and fill in all values before running in production.
# NEVER commit .env to version control.

# ---- Flask Core ----
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=0

# ---- Database ----
# Use PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/goodgurl
# SQLite fallback for local dev only:
DATABASE_URL=sqlite:///goodgurl.db

# ---- Email (SMTP) ----
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@goodgurl.gg

# ---- Rate Limiter (Redis recommended for production) ----
# LIMITER_STORAGE_URI=redis://localhost:6379/0
# Leave unset to use in-memory (dev only):
LIMITER_STORAGE_URI=memory://

# ---- Sentry (error monitoring) ----
# Get your DSN from https://sentry.io
SENTRY_DSN=

# ---- GG TV / Bot Streams ----
MEDIAMTX_RTMP=rtmp://localhost:1935/live
MEDIAMTX_HLS=http://localhost:8888
